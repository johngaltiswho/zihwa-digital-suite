{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["apps/stalknspice-storefront/**"]
  },
  "deploy": {
    "startCommand": "cd apps/stalknspice-storefront && node ../../node_modules/.bin/next start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
