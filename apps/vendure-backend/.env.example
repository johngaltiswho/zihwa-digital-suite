# Application Environment (dev or production)
APP_ENV=dev

# Server Configuration
PORT=3100

# Authentication
COOKIE_SECRET=your-secure-random-cookie-secret-here
SUPERADMIN_USERNAME=your-admin-username
SUPERADMIN_PASSWORD=your-secure-admin-password

# Node.js Options
NODE_OPTIONS=--dns-result-order=ipv4first

# Database Configuration
# Use Supabase connection pooler for better reliability
DATABASE_URL=postgresql://username:password@host:port/database

DB_HOST=your-db-host
DB_PORT=6543
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password
DB_NAME=postgres
DB_SCHEMA=vendure
DB_SYNCHRONIZE=false

# Razorpay Payment Gateway
# Get your credentials from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Supabase Storage Configuration
SUPABASE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-southeast-2
SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
SUPABASE_STORAGE_BUCKET=assets
SUPABASE_PUBLIC_URL=https://your-project.supabase.co/storage/v1/object/public/assets

# Production Frontend URLs (for CORS)
# FRONTEND_URL=https://stalknspice.com
# RAILWAY_STATIC_URL=https://your-app.railway.app

# Email delivery
# true  => write emails to /mailbox and static/email/test-emails (local dev)
# false => send real emails via SMTP_* settings below
EMAIL_DEV_MODE=true
EMAIL_FROM_ADDRESS="Stalks N Spice <noreply@stalksnspice.com>"
PASSWORD_RESET_URL=http://localhost:3006/account/reset-password
VERIFY_EMAIL_URL=http://localhost:3003/verify
CHANGE_EMAIL_ADDRESS_URL=http://localhost:3003/verify-email-address-change

# SMTP (required when EMAIL_DEV_MODE=false)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your-smtp-api-key-or-password
